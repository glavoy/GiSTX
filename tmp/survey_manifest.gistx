      "requireslink": 0
    },
    {
      "display_order": 20,
      "tablename": "followup",
      "displayname": "Followup Survey",
      "isbase": 0,
      "primarykey": "subjid,vdate",
      "linkingfield": "subjid",
      "parenttable": "enrollment",
      "requireslink": 1
    },
    {
      "display_order": 30,
      "tablename": "swf",
      "displayname": "Subject Withdrawal Form",
      "isbase": 0,
      "primarykey": "subjid",
      "linkingfield": "subjid",
      "parenttable": "enrollment",
      "requireslink": 1
    }
  ]
