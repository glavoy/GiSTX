    "followup.xml",
    "swf.xml"
  ],
  "crfs": [
    {
      "display_order": 10,
      "tablename": "enrollment",
      "displayname": "Enrollment Form",
      "isbase": 1,
      "primarykey": "subjid",
      "idconfig": {
        "prefix": "GX",
        "fields": [{"name":"tabletnum","length":2}],
        "incrementLength": 3
